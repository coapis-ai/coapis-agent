# ============================================================
# CoApis .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
*.whl
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Node.js / Frontend ---
node_modules/
*.local
.DS_Store

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Environment / Secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# --- Docker ---
docker/.env
docker/.env.dev
*.log

# --- OS ---
.DS_Store
Thumbs.db

# --- Backup / Temp ---
*.bak
*.bak*
*.tmp
~$*
*_bak_*

# --- Local config (use *.example as template) ---
docker/config/config.json
docker/config/providers.json

# --- Runtime data (bind mounted from host) ---
workspaces/
memory/
MEMORY.md
PROFILE.md
SOUL.md
AGENTS.md
HEARTBEAT.md
*.json.lock
.reme_store_v1
.bootstrap_completed

# --- Debug / temp scripts (root directory) ---
debug_config*.py
fix_*.py
find_bad_jobs.py
test_*.py
verify_*.py

# --- Screenshot / verify images ---
*.png

# --- One-time docs ---
PROJECT_REORGANIZATION_COMPLETE.md

# --- Reports (generated / internal) ---
docs/*.docx
docs/*.js
docs/package*.json

# --- Scripts (local dev only) ---
scripts/

# --- Client build artifacts ---
client/node_modules/.tmp
client/dist/

# --- Playwright browser binaries (too large for git) ---
docker/volume/
server/deploy/chromium-cache/

# --- Dev-only docker compose ---
docker/docker-compose.dev.yaml
docker/dev-overrides/

# --- Standalone dev/ops scripts (not part of coapis package) ---
server/configure_llm.py
server/restart_backend.py
