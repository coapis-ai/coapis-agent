# ═══════════════════════════════════════════════════════════════════
# CoApis 环境配置示例
# 复制此文件为 .env 并修改配置
# ═══════════════════════════════════════════════════════════════════

# ── 镜像配置 ──────────────────────────────────────────────────────
# 使用 GitHub Container Registry 镜像（推荐）
COAPIS_IMAGE=ghcr.io/coapis-ai/coapis-agent/server:latest

# 或使用特定版本
# COAPIS_IMAGE=ghcr.io/coapis-ai/coapis-agent/server:v1.0.0

# 或使用开发版本
# COAPIS_IMAGE=ghcr.io/coapis-ai/coapis-agent/server:dev

# ── 端口配置 ──────────────────────────────────────────────────────
COAPIS_SERVER_PORT=4208

# ── 数据目录 ──────────────────────────────────────────────────────
COAPIS_WORKING_DIR=/apps/ai/coapis
COAPIS_WORKSPACES_DIR=${COAPIS_WORKING_DIR}/workspaces

# ── 其他配置 ──────────────────────────────────────────────────────
# 日志级别
LOG_LEVEL=INFO

# 时区
TZ=Asia/Shanghai
