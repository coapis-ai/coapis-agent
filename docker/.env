# ═══════════════════════════════════════════════════════════════════
# CoApis 环境变量配置
# 由 docker-compose 的 env_file 加载
# ═══════════════════════════════════════════════════════════════════

# ── 基础配置 ──
COAPIS_WEB_PORT=4200
COAPIS_SERVER_PORT=4208

COAPIS_VERSION=0.8.60

COAPIS_WORKING_DIR=/apps/ai/coapis
# COAPIS_WORKSPACES_DIR - 用户空间存储目录，默认 {WORKING_DIR}/workspaces
# 如需分离存储（如 NFS），修改为独立路径
COAPIS_WORKSPACES_DIR=${COAPIS_WORKING_DIR}/workspaces

# ── Playwright 浏览器服务 ──
COAPIS_PLAYWRIGHT_PORT=4201

# ── 文件上传 ──
# 单次上传最大文件数
COAPIS_UPLOAD_MAX_FILES=10
# 单个文件最大体积 (MB)，nginx 和后端共用
COAPIS_UPLOAD_MAX_FILE_SIZE_MB=20

# ── Web 搜索 ──
# 默认搜索后端：auto / browser / tavily / bocha / ddgs / baidu / sogou
# COAPIS_WEB_SEARCH_DEFAULT_BACKEND=auto
# fallback 顺序（逗号分隔），browser 优先（Playwright 真实浏览器）
# COAPIS_WEB_SEARCH_BACKEND_ORDER=browser,tavily,bocha,ddgs,baidu,sogou
# 搜索结果缓存时间（秒）
# COAPIS_WEB_SEARCH_CACHE_TTL=600
# 单次搜索超时（秒）
# COAPIS_WEB_SEARCH_TIMEOUT=15

# 进化系统自动审核阈值
COAPIS_AUTO_APPROVE_CONFIDENCE=0.8
COAPIS_SKILL_AUTO_REVIEW_THRESHOLD=0.5
