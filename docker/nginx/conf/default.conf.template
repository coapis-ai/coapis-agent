server {
    listen 80;
    server_name localhost;

    # ── 上传大小限制（由 .env 的 COAPIS_UPLOAD_MAX_FILE_SIZE_MB 控制） ──
    client_max_body_size ${COAPIS_UPLOAD_MAX_BODY_SIZE}m;

    # ── 安全头 ──
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # ── Gzip ──
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml image/svg+xml;
    gzip_min_length 1000;

    root /usr/share/nginx/html;
    index index.html;

    # ═══════════════════════════════════════════════════════
    # 1. 后端 API：/api/ → server:8000
    # ═══════════════════════════════════════════════════════

    # /api/agent/ — AgentScope SSE 长连接（^~ 优先匹配，300s 超时）
    location ^~ /api/agent/ {
        proxy_pass http://server:8000/api/agent/;
        proxy_set_header Host              $host;
        proxy_set_header Authorization     $http_authorization;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    300s;
    }

    # /api/ — 所有后端 API（REST + WebSocket）
    location /api/ {
        proxy_pass http://server:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header Authorization     $http_authorization;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    300s;
    }

    # ═══════════════════════════════════════════════════════
    # 2. 前端静态资源
    # ═══════════════════════════════════════════════════════

    # index.html — 不缓存（确保总能拿到最新版本）
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
        try_files $uri =404;
    }

    # 带 hash 的静态资源 — 长期缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ═══════════════════════════════════════════════════════
    # 3. SPA 回退 — 其余所有请求 → index.html
    # ═══════════════════════════════════════════════════════

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# WebSocket 升级映射
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
