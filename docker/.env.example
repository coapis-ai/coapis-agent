# ═══════════════════════════════════════════════════════════
# CoApis Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Most variables have sensible defaults; only set what you need to override.
#
# Priority:
#   1. Value in .env file (if it exists at project root)
#   2. System environment variable
#   3. Built-in default
# ═══════════════════════════════════════════════════════════

# ── Core Paths ──────────────────────────────────────────────
# Working directory (where CoApis stores its runtime data).
# Default: ~/.coapis (or ~/.copaw if legacy dir exists)
# COAPIS_WORKING_DIR=/opt/coapis

# User workspaces directory (isolated per user, can use separate storage).
# Default: {COAPIS_WORKING_DIR}/workspaces
# COAPIS_WORKSPACES_DIR=/mnt/nfs/workspaces

# Secret directory (for API keys, tokens, etc.).
# Default: {COAPIS_WORKING_DIR}.secret
# COAPIS_SECRET_DIR=/opt/coapis.secret

# Backup directory.
# Default: {COAPIS_WORKING_DIR}.backups
# COAPIS_BACKUP_DIR=/mnt/backups/coapis

# ── LLM Configuration ──────────────────────────────────────
# OpenAI-compatible API key (required for most providers).
# OPENAI_API_KEY=sk-...

# OpenAI-compatible API base URL.
# OPENAI_API_BASE=https://api.openai.com/v1

# DASHSCOPE (Alibaba Cloud) API base URL.
# Default: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── LLM Rate Limiting & Concurrency ────────────────────────
# Maximum concurrent in-flight LLM calls.
# Default: 10
# COAPIS_LLM_MAX_CONCURRENT=10

# Maximum queries per minute (0 = unlimited).
# Default: 600
# COAPIS_LLM_MAX_QPM=600

# Max retries per LLM call.
# Default: 3
# COAPIS_LLM_MAX_RETRIES=3

# Backoff base (seconds).
# Default: 1.0
# COAPIS_LLM_BACKOFF_BASE=1.0

# Backoff cap (seconds).
# Default: 10.0
# COAPIS_LLM_BACKOFF_CAP=10.0

# Pause duration on 429 (seconds).
# Default: 5.0
# COAPIS_LLM_RATE_LIMIT_PAUSE=5.0

# Jitter range on pause (seconds).
# Default: 1.0
# COAPIS_LLM_RATE_LIMIT_JITTER=1.0

# Timeout for acquiring semaphore slot (seconds).
# Default: 300.0
# COAPIS_LLM_ACQUIRE_TIMEOUT=300.0

# ── Authentication ──────────────────────────────────────────
# Enable authentication system.
# Set to true/false/1/0/yes/no.
# Default: false
# COAPIS_AUTH_ENABLED=false

# ── Logging ─────────────────────────────────────────────────
# Log level for the application.
# Options: debug, info, warning, error, critical.
# COAPIS_LOG_LEVEL=info

# ── Development & Debugging ─────────────────────────────────
# Enable OpenAPI docs (/docs, /redoc, /openapi.json).
# WARNING: Keep false in production.
# Default: false
# COAPIS_OPENAPI_DOCS=false

# CORS origins (comma-separated). When unset, CORS middleware is disabled.
# Example: COAPIS_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
# COAPIS_CORS_ORIGINS=

# Indicate running inside a container (e.g. Docker).
# Default: false
# COAPIS_RUNNING_IN_CONTAINER=false

# ── Memory Configuration ────────────────────────────────────
# Number of recent memories to keep during compaction.
# Default: 3
# COAPIS_MEMORY_COMPACT_KEEP_RECENT=3

# Memory compaction ratio.
# Default: 0.7
# COAPIS_MEMORY_COMPACT_RATIO=0.7

# ── Tool Guard ──────────────────────────────────────────────
# Approval timeout for tool guard (seconds).
# Default: 300
# COAPIS_TOOL_GUARD_APPROVAL_TIMEOUT_SECONDS=300

# Heartbeat interval during approval wait (seconds).
# Default: 15
# COAPIS_TOOL_GUARD_APPROVAL_HEARTBEAT_INTERVAL=15

# ── File Names (relative to WORKING_DIR) ───────────────────
# Jobs file name.
# Default: jobs.json
# COAPIS_JOBS_FILE=jobs.json

# Chats file name.
# Default: chats.json
# COAPIS_CHATS_FILE=chats.json

# Token usage file name.
# Default: token_usage.json
# COAPIS_TOKEN_USAGE_FILE=token_usage.json

# Config file name.
# Default: config.json
# COAPIS_CONFIG_FILE=config.json

# Heartbeat file name.
# Default: HEARTBEAT.md
# COAPIS_HEARTBEAT_FILE=HEARTBEAT.md

# Debug history file name.
# Default: debug_history.jsonl
# COAPIS_DEBUG_HISTORY_FILE=debug_history.jsonl

# ── Provider Check Timeout ──────────────────────────────────
# Timeout in seconds for checking if a provider is reachable.
# Default: 5.0
# COAPIS_MODEL_PROVIDER_CHECK_TIMEOUT=5.0

# ── Playwright ──────────────────────────────────────────────
# Use system Chromium when set (e.g. in Docker).
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
